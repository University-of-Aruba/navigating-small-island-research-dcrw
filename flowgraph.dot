  d01 -> n02[label="no"];
  n02 -> n03;
  n03 -> d03;

  d01 -> n04[label="yes"];
  n04 -> n05;
  n05 -> d02;

  d02 -> n01[label="yes"];
  d02 -> d03[label="no"];

  d03 -> n01[label="yes"];
  d03 -> d04[label="no"];

  d04 -> n06[label="yes"];

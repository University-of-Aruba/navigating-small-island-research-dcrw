  n04   [label="(re)define personal/contextual hypothesis"];
  n05   [label="(re)set max sample size"];
  d03   [label="expected sample quality low?"];
  d04   [label="local ethics committee absent?"];
  n06   [label="ensure compliance"];
  d05   [label="pseudo anonymization insufficient?"];
